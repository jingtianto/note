@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

if "%~1"=="" (
    echo 请把 Excel 文件拖到本批处理上使用
    pause >nul
    exit /b
)

set "excel_file=%~1"
set "vbs_script=%temp%\~read_cell.vbs"

:: 生成 VBS 读取 ECU_Config!B65
echo Set objExcel = CreateObject("Excel.Application") > "%vbs_script%"
echo objExcel.Visible = False >> "%vbs_script%"
echo objExcel.DisplayAlerts = False >> "%vbs_script%"
echo Set objWB = objExcel.Workbooks.Open("%excel_file%") >> "%vbs_script%"
echo On Error Resume Next >> "%vbs_script%"
echo Set objWS = objWB.Sheets("ECU_Config") >> "%vbs_script%"
echo If Err.Number ^<^> 0 Then >> "%vbs_script%"
echo     WScript.Echo "ERR_SHEET" >> "%vbs_script%"
echo     objWB.Close False >> "%vbs_script%"
echo     objExcel.Quit >> "%vbs_script%"
echo     WScript.Quit >> "%vbs_script%"
echo End If >> "%vbs_script%"
echo On Error GoTo 0 >> "%vbs_script%"
echo cellVal = objWB.Sheets("ECU_Config").Range("B65").Value >> "%vbs_script%"
echo If IsEmpty(cellVal) Then >> "%vbs_script%"
echo     WScript.Echo "ERR_EMPTY" >> "%vbs_script%"
echo Else >> "%vbs_script%"
echo     WScript.Echo cellVal >> "%vbs_script%"
echo End If >> "%vbs_script%"
echo objWB.Close False >> "%vbs_script%"
echo objExcel.Quit >> "%vbs_script%"

:: 执行 VBS 并获取名称
for /f "delims=" %%a in ('cscript //nologo "%vbs_script%"') do set "new_name=%%a"
del "%vbs_script%"

if "!new_name!"=="ERR_SHEET" (
    echo 错误：未找到工作表 ECU_Config
    pause >nul
    exit /b
)
if "!new_name!"=="ERR_EMPTY" (
    echo 错误：B65 单元格为空
    pause >nul
    exit /b
)

:: 清理非法字符
set "new_name=!new_name::=_!"
set "new_name=!new_name:\=_!"
set "new_name=!new_name:/=_!"
set "new_name=!new_name:*=_!"
set "new_name=!new_name:?=_!"
set "new_name=!new_name:"=_!"
set "new_name=!new_name:<=_!"
set "new_name=!new_name:>=_!"
set "new_name=!new_name:|=_!"

:: 重命名
set "ext=%~x1"
set "dir=%~dp1"
ren "%excel_file%" "!new_name!!ext!"

echo 已重命名为：!new_name!!ext!
echo.
pause >nul