Sub CopyVisibleAndClean_Strict_WithIDCheck()
    Dim originalWs As Worksheet, newWs As Worksheet
    Dim newSheetName As String
    Dim visibleRange As Range
    Dim headers As Variant
    Dim searchStartRow As Long, searchEndRow As Long
    Dim headerRow As Long, r As Long, i As Integer
    Dim lastCol As Long, col As Long
    Dim keepCols As Collection
    Dim colToDelete As Range
    Dim octaneCol As Long, idCol As Long   ' 新增 idCol 变量
    Dim found As Boolean
    Dim lastRow As Long
    
    ' ========== 参数设置 ==========
    newSheetName = "IPN_1"
    headers = Array("ID", "Testfallname", "Octane-ID")
    searchStartRow = 1
    searchEndRow = 10      ' 扫描前10行寻找标题行
    
    ' 当前工作表（假设为 IPN）
    Set originalWs = ActiveSheet
    If originalWs.Name <> "IPN" Then
        If MsgBox("当前活动表不是 'IPN'，是否继续？（将复制当前表的可见内容）", vbYesNo + vbQuestion) = vbNo Then Exit Sub
    End If
    
    ' 处理已存在的目标表
    Application.DisplayAlerts = False
    On Error Resume Next
    Set newWs = Worksheets(newSheetName)
    If Not newWs Is Nothing Then
        On Error GoTo 0
        If MsgBox("工作表 '" & newSheetName & "' 已存在，是否删除并重建？", vbYesNo + vbWarning) = vbYes Then
            newWs.Delete
        Else
            MsgBox "操作已取消。", vbInformation
            Exit Sub
        End If
    End If
    On Error GoTo 0
    Application.DisplayAlerts = True
    
    ' ========== 1. 复制可见内容 ==========
    On Error Resume Next
    Set visibleRange = originalWs.UsedRange.SpecialCells(xlCellTypeVisible)
    On Error GoTo 0
    
    If visibleRange Is Nothing Then
        MsgBox "原始表中没有可见单元格。", vbExclamation
        Exit Sub
    End If
    
    Set newWs = Worksheets.Add(After:=originalWs)
    newWs.Name = newSheetName
    visibleRange.Copy
    newWs.Range("A1").PasteSpecial Paste:=xlPasteAll
    Application.CutCopyMode = False
    
    MsgBox "已复制可见内容到新表 '" & newSheetName & "'，开始清理...", vbInformation
    
    ' ========== 2. 定位真正的标题行（包含所有三个列名） ==========
    headerRow = 0
    For r = searchStartRow To searchEndRow
        If r <= newWs.UsedRange.Rows.Count + newWs.UsedRange.Row - 1 Then
            Dim allFound As Boolean
            allFound = True
            For i = LBound(headers) To UBound(headers)
                Dim foundCell As Range
                Set foundCell = newWs.Rows(r).Find(What:=headers(i), LookIn:=xlValues, LookAt:=xlPart, MatchCase:=False)
                If foundCell Is Nothing Then
                    allFound = False
                    Exit For
                End If
            Next i
            If allFound Then
                headerRow = r
                Exit For
            End If
        End If
    Next r
    
    If headerRow = 0 Then
        MsgBox "未找到包含 " & Join(headers, ", ") & " 的标题行（已扫描前 " & searchEndRow & " 行）。", vbExclamation
        Exit Sub
    End If
    
    ' 删除标题行以上的行
    If headerRow > 1 Then
        newWs.Rows("1:" & headerRow - 1).Delete Shift:=xlUp
    End If
    ' 此时标题行变为第1行
    
    ' ========== 3. 只保留指定的三列 ==========
    lastCol = newWs.Cells(1, newWs.Columns.Count).End(xlToLeft).Column
    Set keepCols = New Collection
    
    For col = 1 To lastCol
        For i = LBound(headers) To UBound(headers)
            If StrComp(Trim(newWs.Cells(1, col).Value), headers(i), vbTextCompare) = 0 Then
                keepCols.Add col
                Exit For
            End If
        Next i
    Next col
    
    If keepCols.Count <> 3 Then
        MsgBox "删除上方行后，未能同时找到三列。找到的列数：" & keepCols.Count, vbExclamation
        Exit Sub
    End If
    
    Set colToDelete = Nothing
    For col = lastCol To 1 Step -1
        found = False
        For i = 1 To keepCols.Count
            If keepCols(i) = col Then found = True: Exit For
        Next i
        If Not found Then
            If colToDelete Is Nothing Then
                Set colToDelete = newWs.Columns(col)
            Else
                Set colToDelete = Union(colToDelete, newWs.Columns(col))
            End If
        End If
    Next col
    If Not colToDelete Is Nothing Then colToDelete.Delete Shift:=xlToLeft
    
    ' ========== 4. 定位 ID 列和 Octane-ID 列 ==========
    lastCol = newWs.Cells(1, newWs.Columns.Count).End(xlToLeft).Column
    idCol = 0
    octaneCol = 0
    For col = 1 To lastCol
        Dim headerVal As String
        headerVal = Trim(newWs.Cells(1, col).Value)
        If StrComp(headerVal, "ID", vbTextCompare) = 0 Then
            idCol = col
        ElseIf StrComp(headerVal, "Octane-ID", vbTextCompare) = 0 Then
            octaneCol = col
        End If
    Next col
    
    If idCol = 0 Then
        MsgBox "清理后未找到 'ID' 列，无法删除 UNGUELTIG 行。", vbExclamation
        Exit Sub
    End If
    If octaneCol = 0 Then
        MsgBox "清理后未找到 'Octane-ID' 列，无法删除空行。", vbExclamation
        Exit Sub
    End If
    
    ' ========== 5. 删除行：条件1 - Octane-ID 为空；条件2 - ID 为 "UNGUELTIG" ==========
    lastRow = newWs.Cells(newWs.Rows.Count, octaneCol).End(xlUp).Row
    Dim deleteCount As Long
    deleteCount = 0
    
    For r = lastRow To 2 Step -1
        Dim shouldDelete As Boolean
        shouldDelete = False
        
        ' 条件1：Octane-ID 为空（严格判断）
        Dim octVal As Variant
        octVal = newWs.Cells(r, octaneCol).Value
        If IsEmpty(octVal) Or IsNull(octVal) Then
            shouldDelete = True
        Else
            Dim strOct As String
            strOct = Trim(CStr(octVal))
            If strOct = "" Then shouldDelete = True
        End If
        
        ' 条件2：ID 列内容为 "UNGUELTIG"（不区分大小写）
        If Not shouldDelete Then
            Dim idVal As Variant
            idVal = newWs.Cells(r, idCol).Value
            If Not IsEmpty(idVal) And Not IsNull(idVal) Then
                If UCase(Trim(CStr(idVal))) = "UNGUELTIG" Then
                    shouldDelete = True
                End If
            End If
        End If
        
        If shouldDelete Then
            newWs.Rows(r).Delete
            deleteCount = deleteCount + 1
        End If
    Next r
    
    ' ========== 6. 自适应调整列宽和行高 ==========
    newWs.Columns.AutoFit
    newWs.Rows.AutoFit
    
    ' ========== 完成提示 ==========
    MsgBox "操作完成！" & vbCrLf & _
           "原始表 '" & originalWs.Name & "' 未受影响。" & vbCrLf & _
           "新表 '" & newSheetName & "' 已完成：" & vbCrLf & _
           "  - 仅复制了原始表中的可见内容（隐藏行列被忽略）" & vbCrLf & _
           "  - 删除了标题行以上的 " & (headerRow - 1) & " 行" & vbCrLf & _
           "  - 保留了列：ID, Testfallname, Octane-ID" & vbCrLf & _
           "  - 共删除了 " & deleteCount & " 行（原因：Octane-ID 为空 或 ID = UNGUELTIG）" & vbCrLf & _
           "  - 已自动调整列宽和行高", vbInformation
End Sub


'======= 5. 删除无效行：Octane-ID为空 或 ID=UNGUELTIG =======
lastRow = newWs.Cells(newWs.Rows.Count, octaneCol).End(xlUp).Row
Dim deleteCount As Long
deleteCount = 0

' 从下往上反向遍历删除（删除行必须Step-1，避免跳行漏删）
For r = lastRow To 2 Step -1
    shouldDelete = False
    
    ' 条件1：Octane-ID列为空/空白
    octVal = newWs.Cells(r, octaneCol).Value
    If IsEmpty(octVal) Or IsNull(octVal) Or Trim(CStr(octVal)) = "" Then
        shouldDelete = True
    End If
    
    ' 条件2：ID列内容为 UNGUELTIG（彻底忽略大小写+首尾空格）
    If Not shouldDelete Then
        idVal = newWs.Cells(r, idCol).Value
        If UCase(Trim(CStr(idVal))) = "UNGUELTIG" Then
            shouldDelete = True
        End If
    End If
    
    ' 满足任一条件就删除
    If shouldDelete Then
        newWs.Rows(r).Delete
        deleteCount = deleteCount + 1
    End If
Next r

'======= 5. 删除无效行（彻底清空UNGUELTIG+空Octane-ID =======
lastRow = newWs.Cells(newWs.Rows.Count, idCol).End(xlUp).Row
deleteCount = 0

' 必须从最后一行 倒着往上删，绝对不会跳行漏删
For r = lastRow To 2 Step -1
    shouldDelete = False
    
    ' 条件1：Octane-ID列为空白/空值
    octVal = newWs.Cells(r, octaneCol).Value
    If Trim(UCase(CStr(octVal))) = "" Then
        shouldDelete = True
    End If

    ' 条件2：ID列 = UNGUELTIG（无视大小写、首尾空格、多余空白）
    idVal = Trim(UCase(CStr(newWs.Cells(r, idCol).Value)))
    If idVal = "UNGUELTIG" Then
        shouldDelete = True
    End If
    
    ' 满足任意条件 立刻删除
    If shouldDelete = True Then
        newWs.Rows(r).Delete
        deleteCount = deleteCount + 1
    End If
Next r
