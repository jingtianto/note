Sub FinalClean_WithFullDebug()
    Dim originalWs As Worksheet, newWs As Worksheet
    Dim newSheetName As String
    Dim visibleRange As Range
    Dim headers As Variant
    Dim searchStartRow As Long, searchEndRow As Long
    Dim headerRow As Long, r As Long, i As Integer
    Dim lastCol As Long, col As Long
    Dim keepCols As Collection
    Dim colToDelete As Range
    Dim octaneCol As Long, idCol As Long
    Dim found As Boolean
    Dim lastRow As Long
    
    ' 参数
    newSheetName = "IPN_1"
    headers = Array("ID", "Testfallname", "Octane-ID")
    searchStartRow = 1
    searchEndRow = 10
    
    Set originalWs = ActiveSheet
    If originalWs.Name <> "IPN" Then
        If MsgBox("当前活动表不是 'IPN'，是否继续？（将复制当前表的可见内容）", vbYesNo + vbQuestion) = vbNo Then Exit Sub
    End If
    
    ' 处理已存在的工作表
    Application.DisplayAlerts = False
    On Error Resume Next
    Set newWs = Worksheets(newSheetName)
    If Not newWs Is Nothing Then
        On Error GoTo 0
        If MsgBox("工作表 '" & newSheetName & "' 已存在，是否删除并重建？", vbYesNo + vbWarning) = vbYes Then
            newWs.Delete
        Else
            MsgBox "操作已取消。", vbInformation
            Exit Sub
        End If
    End If
    On Error GoTo 0
    Application.DisplayAlerts = True
    
    ' 1. 复制可见内容
    On Error Resume Next
    Set visibleRange = originalWs.UsedRange.SpecialCells(xlCellTypeVisible)
    On Error GoTo 0
    If visibleRange Is Nothing Then
        MsgBox "原始表中没有可见单元格。", vbExclamation
        Exit Sub
    End If
    
    Set newWs = Worksheets.Add(After:=originalWs)
    newWs.Name = newSheetName
    visibleRange.Copy
    newWs.Range("A1").PasteSpecial Paste:=xlPasteAll
    Application.CutCopyMode = False
    MsgBox "已复制可见内容到新表 '" & newSheetName & "'，开始清理..."
    
    ' 2. 查找标题行（允许列名部分匹配，但要求三个列名都在同一行）
    headerRow = 0
    For r = searchStartRow To searchEndRow
        If r <= newWs.UsedRange.Rows.Count + newWs.UsedRange.Row - 1 Then
            Dim allFound As Boolean: allFound = True
            For i = LBound(headers) To UBound(headers)
                Dim f As Range
                Set f = newWs.Rows(r).Find(What:=headers(i), LookIn:=xlValues, LookAt:=xlPart, MatchCase:=False)
                If f Is Nothing Then allFound = False: Exit For
            Next i
            If allFound Then headerRow = r: Exit For
        End If
    Next r
    If headerRow = 0 Then
        MsgBox "未找到包含 " & Join(headers, ", ") & " 的标题行。", vbExclamation
        Exit Sub
    End If
    If headerRow > 1 Then newWs.Rows("1:" & headerRow - 1).Delete Shift:=xlUp
    
    ' 3. 只保留三列
    lastCol = newWs.Cells(1, newWs.Columns.Count).End(xlToLeft).Column
    Set keepCols = New Collection
    For col = 1 To lastCol
        For i = LBound(headers) To UBound(headers)
            If StrComp(Trim(newWs.Cells(1, col).Value), headers(i), vbTextCompare) = 0 Then
                keepCols.Add col
                Exit For
            End If
        Next i
    Next col
    If keepCols.Count <> 3 Then
        MsgBox "删除上方行后，未能同时找到三列。", vbExclamation
        Exit Sub
    End If
    Set colToDelete = Nothing
    For col = lastCol To 1 Step -1
        found = False
        For i = 1 To keepCols.Count
            If keepCols(i) = col Then found = True: Exit For
        Next i
        If Not found Then
            If colToDelete Is Nothing Then Set colToDelete = newWs.Columns(col) Else Set colToDelete = Union(colToDelete, newWs.Columns(col))
        End If
    Next col
    If Not colToDelete Is Nothing Then colToDelete.Delete Shift:=xlToLeft
    
    ' 4. 定位 ID 和 Octane-ID 列
    lastCol = newWs.Cells(1, newWs.Columns.Count).End(xlToLeft).Column
    idCol = 0: octaneCol = 0
    For col = 1 To lastCol
        Dim hv As String: hv = Trim(newWs.Cells(1, col).Value)
        If StrComp(hv, "ID", vbTextCompare) = 0 Then idCol = col
        If StrComp(hv, "Octane-ID", vbTextCompare) = 0 Then octaneCol = col
    Next col
    If idCol = 0 Or octaneCol = 0 Then
        MsgBox "未能定位 ID 或 Octane-ID 列。", vbExclamation
        Exit Sub
    End If
    
    ' 调试输出：列号
    Debug.Print "ID列号: " & idCol & " , Octane-ID列号: " & octaneCol
    
    ' 5. 获取最大行号（取两列中的最大非空行，避免遗漏）
    Dim lastRowID As Long, lastRowOct As Long
    lastRowID = newWs.Cells(newWs.Rows.Count, idCol).End(xlUp).Row
    lastRowOct = newWs.Cells(newWs.Rows.Count, octaneCol).End(xlUp).Row
    lastRow = Application.WorksheetFunction.Max(lastRowID, lastRowOct)
    If lastRow < 2 Then lastRow = 2
    
    ' 辅助清理函数
    Function CleanStr(v As Variant) As String
        If IsNull(v) Or IsEmpty(v) Then CleanStr = "": Exit Function
        Dim s As String: s = CStr(v)
        ' 移除所有控制字符（回车、换行、制表符等）
        s = Replace(s, vbCr, "")
        s = Replace(s, vbLf, "")
        s = Replace(s, vbTab, "")
        s = Replace(s, Chr(160), " ")  ' 非断空格
        CleanStr = Trim(s)
    End Function
    
    Dim delCount As Long, ungueltigDel As Long, emptyOctDel As Long
    delCount = 0: ungueltigDel = 0: emptyOctDel = 0
    
    ' 从下往上遍历所有数据行（第2行到最后一行）
    For r = lastRow To 2 Step -1
        Dim del As Boolean: del = False
        
        ' 检查 Octane-ID
        Dim octVal As Variant: octVal = newWs.Cells(r, octaneCol).Value
        Dim octClean As String: octClean = CleanStr(octVal)
        If octClean = "" Then
            del = True
            emptyOctDel = emptyOctDel + 1
            Debug.Print "行 " & r & " 因 Octane-ID 为空被标记删除"
        End If
        
        ' 检查 ID 是否为 UNGUELTIG
        If Not del Then
            Dim idVal As Variant: idVal = newWs.Cells(r, idCol).Value
            Dim idClean As String: idClean = CleanStr(idVal)
            If UCase(idClean) = "UNGUELTIG" Then
                del = True
                ungueltigDel = ungueltigDel + 1
                Debug.Print "行 " & r & " 因 ID = '" & idClean & "' 被标记删除"
            ElseIf idClean <> "" Then
                ' 可选：输出非 UNGUELTIG 的 ID 值，帮助确认
                ' Debug.Print "行 " & r & " ID = '" & idClean & "' (保留)"
            End If
        End If
        
        If del Then
            newWs.Rows(r).Delete
            delCount = delCount + 1
        End If
    Next r
    
    ' 6. 自适应列宽行高
    newWs.Columns.AutoFit
    newWs.Rows.AutoFit
    
    MsgBox "操作完成！" & vbCrLf & _
           "共删除 " & delCount & " 行，其中：" & vbCrLf & _
           "  - Octane-ID 为空: " & emptyOctDel & " 行" & vbCrLf & _
           "  - ID = UNGUELTIG: " & ungueltigDel & " 行" & vbCrLf & _
           "详细信息请查看VBA立即窗口（Ctrl+G）。", vbInformation
End Sub