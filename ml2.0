Sub ProcessCopyInNewSheet()
    Dim originalWs As Worksheet
    Dim newWs As Worksheet
    Dim newSheetName As String
    Dim lastCol As Long, lastRow As Long
    Dim col As Long, i As Integer, r As Long
    Dim headers As Variant
    Dim keepCols As Collection
    Dim colToDelete As Range
    Dim octaneCol As Long
    Dim found As Boolean
    
    ' 设定新表名称
    newSheetName = "IPN_1"
    
    ' 当前活动工作表（即原始的 IPN 表）
    Set originalWs = ActiveSheet
    If originalWs.Name <> "IPN" Then
        If MsgBox("当前活动工作表不是 'IPN'，是否仍要继续？(将复制当前表)", vbYesNo + vbQuestion) = vbNo Then Exit Sub
    End If
    
    ' 处理可能已存在同名工作表
    Application.DisplayAlerts = False
    On Error Resume Next
    Set newWs = Worksheets(newSheetName)
    If Not newWs Is Nothing Then
        On Error GoTo 0
        If MsgBox("工作表 '" & newSheetName & "' 已存在，是否删除并重新创建？" & vbCrLf & _
                  "（原数据将被覆盖）", vbYesNo + vbWarning) = vbYes Then
            newWs.Delete
        Else
            MsgBox "操作已取消。", vbInformation
            Exit Sub
        End If
    End If
    On Error GoTo 0
    Application.DisplayAlerts = True
    
    ' 复制原始表内容到新表
    originalWs.Copy After:=originalWs
    Set newWs = ActiveSheet
    newWs.Name = newSheetName
    
    MsgBox "已创建新工作表 '" & newSheetName & "' 并复制了原始数据，接下来将进行清理操作。", vbInformation
    
    ' ---------- 1. 保留指定三列，删除其他列 ----------
    headers = Array("ID", "Testfallname", "Octane id")
    lastCol = newWs.Cells(1, newWs.Columns.Count).End(xlToLeft).Column
    Set keepCols = New Collection
    
    For col = 1 To lastCol
        For i = LBound(headers) To UBound(headers)
            If StrComp(Trim(newWs.Cells(1, col).Value), headers(i), vbTextCompare) = 0 Then
                keepCols.Add col
                Exit For
            End If
        Next i
    Next col
    
    If keepCols.Count <> 3 Then
        MsgBox "未找到全部三列，请检查标题行是否包含：" & vbCrLf & _
               "ID, Testfallname, Octane id", vbExclamation
        Exit Sub
    End If
    
    Set colToDelete = Nothing
    For col = lastCol To 1 Step -1
        found = False
        For i = 1 To keepCols.Count
            If keepCols(i) = col Then found = True: Exit For
        Next i
        If Not found Then
            If colToDelete Is Nothing Then
                Set colToDelete = newWs.Columns(col)
            Else
                Set colToDelete = Union(colToDelete, newWs.Columns(col))
            End If
        End If
    Next col
    
    If Not colToDelete Is Nothing Then colToDelete.Delete Shift:=xlToLeft
    
    ' ---------- 2. 删除第一行 ----------
    newWs.Rows(1).Delete Shift:=xlUp
    
    ' ---------- 3. 删除 Octane id 列为空的行 ----------
    ' 重新定位 Octane id 列（现在新表的第一行是原第二行，即新表头）
    lastCol = newWs.Cells(1, newWs.Columns.Count).End(xlToLeft).Column
    octaneCol = 0
    For col = 1 To lastCol
        If StrComp(Trim(newWs.Cells(1, col).Value), "Octane id", vbTextCompare) = 0 Then
            octaneCol = col
            Exit For
        End If
    Next col
    
    If octaneCol = 0 Then
        MsgBox "删除第一行后未找到 'Octane id' 列，无法删除空行。", vbExclamation
        Exit Sub
    End If
    
    lastRow = newWs.Cells(newWs.Rows.Count, octaneCol).End(xlUp).Row
    For r = lastRow To 2 Step -1
        If IsEmpty(newWs.Cells(r, octaneCol).Value) Or Trim(newWs.Cells(r, octaneCol).Value) = "" Then
            newWs.Rows(r).Delete Shift:=xlUp
        End If
    Next r
    
    ' 完成提示
    MsgBox "操作完成！" & vbCrLf & _
           "原始工作表 '" & originalWs.Name & "' 未受影响。" & vbCrLf & _
           "新工作表 '" & newSheetName & "' 已完成：" & vbCrLf & _
           "  1. 仅保留 ID, Testfallname, Octane id 三列" & vbCrLf & _
           "  2. 已删除第一行" & vbCrLf & _
           "  3. 已删除所有 Octane id 为空的行", vbInformation
End Sub