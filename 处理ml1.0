import os
import tkinter as tk
from tkinter import filedialog, messagebox
from openpyxl import load_workbook

# -------------------------- 配置项
# 需要保留的表头关键字
KEEP_KEYWORDS = {"id", "octane", "signalname"}
# 查找标识
TARGET_TEXT = "TestPackage"
# --------------------------

def get_index_color(cell):
    """获取单元格背景色 IndexColor"""
    fill_color = cell.fill.fgColor
    if fill_color.indexed is not None and fill_color.indexed != 0:
        return fill_color.indexed
    return ""

def select_file_or_folder():
    """弹窗：选择单个文件 / 文件夹"""
    root = tk.Tk()
    root.withdraw()
    res = messagebox.askyesno("选择处理方式", "是否批量处理整个文件夹？\n【是】文件夹  【否】单个Excel文件")
    if res:
        path = filedialog.askdirectory(title="请选择Excel所在文件夹")
        return path, "folder"
    else:
        path = filedialog.askopenfilename(
            title="请选择Excel文件",
            filetypes=[("Excel 文件", "*.xlsx;*.xlsm")]
        )
        return path, "file"

def get_first_testpackage_right_value(wb):
    """
    遍历所有Sheet，从上到下查找第一个 TestPackage
    返回它右侧单元格的内容，找不到返回空
    """
    for ws in wb.worksheets:
        for row in ws.iter_rows():
            for cell in row:
                cell_val = str(cell.value).strip() if cell.value else ""
                if TARGET_TEXT in cell_val:
                    # 取右边一格
                    right_col = cell.column + 1
                    if right_col <= ws.max_column:
                        right_val = ws.cell(row=cell.row, column=right_col).value
                        if right_val:
                            return str(right_val).strip()
    return ""

def keep_target_columns_only(ws):
    """
    只保留表头包含 ID / Octane / Signalname 的列
    其余列全部删除（从后往前删，防止列索引错乱）
    """
    if ws.max_row < 1:
        return

    header_row = 1
    keep_col_nums = []

    # 先记录要保留的列序号
    for col in range(1, ws.max_column + 1):
        header_val = ws.cell(row=header_row, column=col).value
        if header_val is None:
            continue
        header_low = str(header_val).lower()
        if any(k in header_low for k in KEEP_KEYWORDS):
            keep_col_nums.append(col)

    # 反向删除不需要的列
    del_cols = [c for c in range(1, ws.max_column + 1) if c not in keep_col_nums]
    for col in sorted(del_cols, reverse=True):
        ws.delete_cols(col)

def process_excel_one(file_path):
    """处理单个Excel文件"""
    try:
        wb = load_workbook(file_path)

        # 1. 新建工作表，存放处理后数据
        new_ws = wb.create_sheet(title="处理结果")
        source_ws = wb.active

        # 复制原表所有数据+单元格格式到新sheet
        for row in source_ws.iter_rows():
            for cell in row:
                new_ws[cell.coordinate].value = cell.value
                new_ws[cell.coordinate].fill = cell.fill.copy()

        # 2. 仅保留 ID、Octane、Signalname 列，删除其他
        keep_target_columns_only(new_ws)

        # 3. 找到ID列，右侧新增IndexColor列，写入颜色索引
        id_col = None
        for col in range(1, new_ws.max_column + 1):
            h_val = new_ws.cell(row=1, column=col).value
            if h_val and "id" in str(h_val).lower():
                id_col = col
                break

        if id_col:
            # ID列右边插入颜色索引列
            new_ws.insert_cols(id_col + 1)
            new_ws.cell(row=1, column=id_col + 1, value="IndexColor")
            # 逐行获取颜色
            for r in range(2, new_ws.max_row + 1):
                color_idx = get_index_color(new_ws.cell(row=r, column=id_col))
                new_ws.cell(row=r, column=id_col + 1, value=color_idx)

        # 4. 查找第一个TestPackage右侧内容，作为新文件名
        new_file_name = get_first_testpackage_right_value(wb)
        dir_path = os.path.dirname(file_path)
        old_name, ext = os.path.splitext(os.path.basename(file_path))

        # 兜底命名
        if not new_file_name:
            new_file_name = old_name + "_已处理"
        new_full_path = os.path.join(dir_path, f"{new_file_name}{ext}")

        # 保存文件
        wb.save(new_full_path)
        wb.close()
        print(f"✅ 处理完成：{new_full_path}")
        return True

    except Exception as e:
        print(f"❌ 处理失败 {file_path} ：{str(e)}")
        return False

def batch_process_folder(folder_path):
    """批量处理文件夹内所有Excel"""
    success = 0
    fail = 0
    for filename in os.listdir(folder_path):
        # 忽略Excel临时缓存文件
        if filename.startswith("~$"):
            continue
        if filename.lower().endswith((".xlsx", ".xlsm")):
            full_path = os.path.join(folder_path, filename)
            if process_excel_one(full_path):
                success += 1
            else:
                fail += 1
    messagebox.showinfo("批量处理结束", f"成功：{success} 个\n失败：{fail} 个")

if __name__ == "__main__":
    # 选择路径
    path, mode = select_file_or_folder()
    if not path:
        messagebox.showwarning("提示", "未选择任何路径，程序退出")
        exit()

    # 执行处理
    if mode == "file":
        process_excel_one(path)
        messagebox.showinfo("提示", "单个文件处理完成！")
    else:
        batch_process_folder(path)