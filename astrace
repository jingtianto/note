Option Explicit

' KEYWORDS (edit here, separated by comma)
Dim keywordsStr
keywordsStr = "none,brake,AccPedal,Speed,Trigger,Acceleration,externalTrigger,limitAcceleration,Pos_BrakePedal"

' COORDINATES (your values)
Const btn_ShowAllX = 33
Const btn_ShowAllY = 201
Const searchBoxX   = 91
Const searchBoxY   = 149
Const btn_ShowX    = 53
Const btn_ShowY    = 222

Dim WSH, FSO, strFile, keywordList, i, kw

Set WSH = CreateObject("WScript.Shell")
Set FSO = CreateObject("Scripting.FileSystemObject")

keywordList = Split(keywordsStr, ",")

' SELECT FILE (100% working PowerShell dialog, no compatibility issues)
strFile = SelectFile()
If strFile = "" Then
    WScript.Echo "No file selected. Exit."
    WScript.Quit
End If

' OPEN FILE
WScript.Echo "Processing: " & FSO.GetFileName(strFile)
WSH.Run """" & strFile & """", 1, False
WScript.Sleep 3000

' MAXIMIZE WINDOW
WSH.AppActivate FSO.GetFileName(strFile)
WScript.Sleep 500
WSH.SendKeys "% "
WScript.Sleep 300
WSH.SendKeys "x"
WScript.Sleep 1500

' CLICK SHOW ALL
Call Click(btn_ShowAllX, btn_ShowAllY)
WScript.Sleep 800

' LOOP KEYWORDS
For i = 0 To UBound(keywordList)
    kw = Trim(keywordList(i))
    If kw <> "" Then
        WScript.Echo "Keyword: " & kw

        ' CLICK SEARCH BOX
        Call Click(searchBoxX, searchBoxY)
        WScript.Sleep 300

        ' CLEAR
        WSH.SendKeys "^a"
        WScript.Sleep 200
        WSH.SendKeys "{DEL}"
        WScript.Sleep 200

        ' INPUT
        WSH.SendKeys kw
        WScript.Sleep 600

        ' CLICK SHOW
        Call Click(btn_ShowX, btn_ShowY)
        WScript.Sleep 800
    End If
Next

WScript.Echo "Done! All keywords finished."

'========================================================
' FUNCTIONS
'========================================================
Sub Click(x, y)
    WSH.Run "powershell -Command ""[System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point(" & x & "," & y & ")""", 0, True
    WScript.Sleep 200
    WSH.Run "powershell -Command ""[System.Windows.Forms.SendKeys]::SendWait('{LEFT}')""", 0, True
    WScript.Sleep 200
End Sub

Function SelectFile()
    Dim psCmd, result
    ' Use PowerShell's built-in file picker, 100% compatible with all Windows versions
    psCmd = "Add-Type -AssemblyName System.Windows.Forms; $dlg = New-Object System.Windows.Forms.OpenFileDialog; $dlg.Filter = 'ASTrace Files (*.astrace)|*.astrace|All Files (*.*)|*.*'; if($dlg.ShowDialog() -eq 'OK') { $dlg.FileName } else { '' }"
    result = WSH.Run("powershell -Command """ & psCmd & """", 0, True)
    SelectFile = Trim(result)
End Function
